{{!< default}}

{{#author}}
<header class="gh-author-header">
    <div class="container">
        {{#if profile_image}}
        <img class="gh-author-header-img" src="{{img_url profile_image size="s"}}" alt="{{name}}" loading="lazy">
        {{/if}}
        <h1 class="gh-author-header-name">{{name}}</h1>
        {{#if bio}}
        <p class="gh-author-header-bio">{{bio}}</p>
        {{/if}}
    </div>
</header>
{{/author}}

<section class="gh-section">
    <div class="container">
        <div class="gh-feed">
            {{#foreach posts}}
                {{> post-card}}
            {{/foreach}}
        </div>
        {{> pagination}}
    </div>
</section>
