{{#if pagination}}
<nav class="gh-pagination" aria-label="Pagination">
    {{#if pagination.prev}}
    <a href="{{page_url pagination.prev}}">&larr; Newer</a>
    {{/if}}
    <span class="gh-pagination-info">Page {{pagination.page}} of {{pagination.pages}}</span>
    {{#if pagination.next}}
    <a href="{{page_url pagination.next}}">Older &rarr;</a>
    {{/if}}
</nav>
{{/if}}
